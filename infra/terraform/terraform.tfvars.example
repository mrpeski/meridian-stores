project_name = "my-calendar-slice"

# Optional: set explicit images; otherwise outputs default to "{project_name}-api:local" style tags.
# fastapi_react_aws_template_api_image = "ghcr.io/example/my-calendar-slice-api:0.1.0"
# fastapi_react_aws_template_web_image = "ghcr.io/example/my-calendar-slice-web:0.1.0"

fastapi_react_aws_template_api_port          = 8000
fastapi_react_aws_template_web_port          = 80
fastapi_react_aws_template_public_hostname   = "meridian-stores.example.com"
fastapi_react_aws_template_api_desired_count = 2
