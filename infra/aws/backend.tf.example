# S3 remote state. Copy this file to `backend.tf` before remote-state init:
# `cp backend.tf.example backend.tf`
#
# Supply `bucket` at init time:
# `terraform init -backend-config=bucket=... -backend-config=region=...`
#
# Keep a unique `key` per project so remote state never collides.

terraform {
  backend "s3" {
    key          = "meridian-stores/main.tfstate"
    region       = "us-east-1"
    encrypt      = true
    use_lockfile = true
  }
}
