# Copy to `meridian-stores/frontend/.env` (Vite loads `.env`, `.env.local`, etc.).

# Production / CI: API Gateway base URL (no trailing slash). Leave unset locally so
# `src/lib/apiBase.ts` uses same-origin `/api/*` and the dev proxy below applies.
# VITE_API_BASE_URL=https://xxxxxxxx.execute-api.us-east-1.amazonaws.com

# Where the browser dev server proxies `/api/*` (must match MERIDIAN_STORES_API_PORT on the API).
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Optional — set when Clerk is enabled on the API.
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Optional alias used by vite.config.ts if VITE_API_PROXY_TARGET is unset.
# VITE_BACKEND_URL=http://127.0.0.1:8000

# Dev / preview bind (defaults shown in vite.config.ts).
VITE_DEV_HOST=0.0.0.0
VITE_DEV_PORT=5173
# VITE_PREVIEW_PORT=4173

# Set to "false" to send the original Host header to the backend (rarely needed locally).
# VITE_PROXY_CHANGE_ORIGIN=true
