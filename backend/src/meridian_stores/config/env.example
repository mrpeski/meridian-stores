# Copy to `meridian-stores/config/.env` (or set path via MERIDIAN_STORES_CONFIG_ENV in Docker Compose).
#
# --- Rename this deployment (single knob) ---
# Used by Docker Compose project name when you run:
#   docker compose --env-file ./config/.env up --build
# Also drives API defaults (FastAPI title, `service` field, hello text) unless you override
# the MERIDIAN_STORES_APP_NAME / MERIDIAN_STORES_SERVICE_NAME / MERIDIAN_STORES_HELLO_MESSAGE vars below.
PROJECT_NAME=meridian-stores

# --- API server (uvicorn) ---
MERIDIAN_STORES_API_HOST=0.0.0.0
MERIDIAN_STORES_API_PORT=8000

# --- HTTP / CORS ---
# Comma-separated browser origins, or * for any (credentials disabled with *).
MERIDIAN_STORES_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Optional identity overrides (omit to derive from PROJECT_NAME) ---
# MERIDIAN_STORES_APP_NAME=my-app
# MERIDIAN_STORES_SERVICE_NAME=my-app-svc
# MERIDIAN_STORES_HELLO_MESSAGE=Hello from my-app.

# --- AI chatbot (POST /api/chat) ---
# OPENAI_API_KEY=sk-proj-...
# MCP_SERVER_URL=https://order-mcp-74afyau24q-uc.a.run.app/mcp
# CHATBOT_MODEL=gpt-4o
# Or prefixed equivalents:
# MERIDIAN_STORES_OPENAI_API_KEY=sk-proj-...
# MERIDIAN_STORES_MCP_SERVER_URL=https://order-mcp-74afyau24q-uc.a.run.app/mcp
# MERIDIAN_STORES_CHATBOT_MODEL=gpt-4o
